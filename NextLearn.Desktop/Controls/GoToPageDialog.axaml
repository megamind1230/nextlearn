<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NextLearn.Desktop.ViewModels"
             x:Class="NextLearn.Desktop.Controls.GoToPageDialog"
             x:DataType="vm:MainWindowViewModel">
    <Panel IsVisible="{Binding LearningViewModel.IsGoToPageOpen}" ZIndex="999">
        <Border Background="{StaticResource ModalBackdropBrush}" PointerPressed="CloseOnBackdrop">
            <Border Background="{StaticResource PanelBgBrush}" CornerRadius="16" Padding="28" Margin="100"
                    VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                <StackPanel Spacing="16">
                    <TextBlock Text="Go to Page" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBox Name="GoToPageTextBox"
                             Text="{Binding LearningViewModel.GoToPageInput}"
                             Watermark="Enter page number..."
                             FontSize="16" Padding="12,8"
                             Background="{StaticResource PageBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                             KeyDown="OnTextBoxKeyDown"/>
                    <TextBlock Text="{Binding LearningViewModel.GoToPageError}"
                               Foreground="{StaticResource AccentRedBrush}" FontSize="13"
                               IsVisible="{Binding LearningViewModel.HasGoToPageError}"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Content="Cancel" Command="{Binding LearningViewModel.CancelGoToPageCommand}"
                                Padding="12,8" Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Grid.Column="1" Content="Go" Command="{Binding LearningViewModel.GoToPageCommand}"
                                Padding="12,8" Background="{StaticResource AccentBlueBrush}" Foreground="White"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>