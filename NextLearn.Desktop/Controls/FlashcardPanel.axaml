<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NextLearn.Desktop.ViewModels"
             xmlns:models="using:NextLearn.Desktop.Models"
             x:Class="NextLearn.Desktop.Controls.FlashcardPanel"
             x:DataType="vm:MainWindowViewModel">
    <Panel IsVisible="{Binding IsFlashcardOpen}" ZIndex="300">
        <DockPanel Background="{StaticResource PanelBgBrush}">
            <Border DockPanel.Dock="Top" Padding="16,12" Background="{StaticResource PanelBgBrush}">
                <DockPanel>
                    <Button Command="{Binding CloseFlashcardPanelCommand}"
                            Background="Transparent" Padding="12,8">
                        <TextBlock Text="← Back" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <TextBlock Text="🃏 Anki Flashcards" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </DockPanel>
            </Border>

            <Border DockPanel.Dock="Top" Height="4" IsVisible="{Binding FlashcardViewModel.IsGenerating}">
                <ProgressBar Value="{Binding FlashcardViewModel.GenerationProgress}"
                             Minimum="0" Maximum="100"
                             Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceBgBrush}" Height="4"/>
            </Border>

            <ScrollViewer x:Name="FlashcardScrollViewer" Margin="24">
                <StackPanel Spacing="16">

                    <TextBlock Text="{Binding FlashcardViewModel.GenerationStatus}"
                               IsVisible="{Binding FlashcardViewModel.IsGenerating}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>

                    <TextBox Text="{Binding FlashcardViewModel.ErrorMessage}"
                             IsVisible="{Binding FlashcardViewModel.HasError}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Padding="8"
                             FontSize="13"
                             Foreground="{StaticResource AccentRedBrush}"
                             Background="{StaticResource PanelBgBrush}"
                             BorderBrush="{StaticResource AccentRedBrush}"
                             MinHeight="40"
                             MaxHeight="300"/>

                    <!-- Success message after export -->
                    <Border IsVisible="{Binding FlashcardViewModel.HasSuccessMessage}"
                            Background="{StaticResource PageBgBrush}" CornerRadius="8" Padding="16"
                            BorderBrush="{StaticResource AccentGreenBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="✅ Export Successful" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                            <TextBlock Text="{Binding FlashcardViewModel.SuccessMessage}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding FlashcardViewModel.ShowDeckList}">
                        <TextBox x:Name="FlashcardSearchBox"
                                 Text="{Binding FlashcardViewModel.SearchText}"
                                 Watermark="🔍 Search by title, description, #tag, or regex…"
                                 Padding="12" FontSize="14"
                                 Foreground="{StaticResource TextPrimaryBrush}" Background="{StaticResource SearchBoxBgBrush}" BorderBrush="{StaticResource BorderDefaultBrush}"/>
                         <CheckBox Grid.Column="1"
                                  IsChecked="{Binding FlashcardViewModel.UseRegex}"
                                  Content="Regex"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"
                                  Background="{StaticResource CheckboxBgBrush}" BorderBrush="{StaticResource AccentAmberBrush}" BorderThickness="1"
                                  Foreground="{StaticResource CheckmarkFgBrush}"/>
                    </Grid>

                    <Border IsVisible="{Binding FlashcardViewModel.IsPreviewVisible}"
                            Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="20"
                            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding FlashcardViewModel.PreviewHeader}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Review the TSV content below. Each line is one flashcard. Accept to save or Cancel to discard."
                                       Foreground="{StaticResource TextAccentBrush}" FontSize="12" TextWrapping="Wrap"/>
                            <Border Background="{StaticResource PageBgBrush}" CornerRadius="8" Padding="16"
                                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                                <TextBox Text="{Binding FlashcardViewModel.PreviewText}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas, Courier New, monospace"
                                         FontSize="12"
                                         Foreground="{StaticResource TextPrimaryBrush}" Background="{StaticResource PageBgBrush}"
                                         BorderThickness="0"
                                         MinHeight="200"
                                         MaxHeight="400"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Command="{Binding FlashcardViewModel.CancelPreviewCommand}"
                                        Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                        Padding="24,10" FontSize="14" Content="Cancel"/>
                                <Button Command="{Binding FlashcardViewModel.AcceptFlashcardsCommand}"
                                        Background="{StaticResource AccentTealBrush}" Foreground="White"
                                        Padding="24,10" FontSize="14" Content="Accept &amp; Export"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FlashcardViewModel.Decks}"
                                  IsVisible="{Binding FlashcardViewModel.ShowDeckList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Deck">
                                <Border Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,16"
                                        BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Basic"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).FlashcardViewModel.GenerateBasicCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource AccentBlueBrush}" Foreground="White"
                                                        Padding="16,8" FontSize="13"/>
                                                <Button Content="Cloze"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).FlashcardViewModel.GenerateClozeCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource AccentPurpleBrush}" Foreground="White"
                                                        Padding="16,8" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,0">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Title}" FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                <TextBlock FontSize="13" Foreground="{StaticResource TextAccentBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                    <Run Text="Name: "/>
                                                    <Run Text="{Binding FileName}"/>
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                                                <Run Text="{Binding PageCount, StringFormat='{}{0} pages'}"/>
                                                <Run Text=" | "/>
                                                <Run Text="{Binding Tags}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Panel>
</UserControl>