<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NextLearn.Desktop.ViewModels"
             x:Class="NextLearn.Desktop.Controls.Sidebar"
             x:DataType="vm:MainWindowViewModel">
    <Panel IsVisible="{Binding IsSidebarOpen}" ZIndex="200">
        <Border Background="{StaticResource ModalBackdropBrush}" PointerPressed="CloseOnBackdrop">
            <Border Background="{StaticResource PanelBgBrush}" Width="280" HorizontalAlignment="Right"
                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1,0,0,0">
                <Grid RowDefinitions="*,Auto,Auto" Margin="20">
                    <ScrollViewer Grid.Row="0">
                        <StackPanel Spacing="16">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Command="{Binding ToggleSidebarCommand}"
                                    Background="Transparent" Padding="6">
                                <TextBlock Text="✕" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                            <TextBlock Text="Sidebar" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </DockPanel>
                        <Border Height="1" Background="{StaticResource SurfaceBgBrush}"/>
                        <Button Command="{Binding OpenDecksFolderCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="📂" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Open Decks Folder" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowPinnedViewCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="📌" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Pinned" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowArchivedViewCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="🗄️" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Archived" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowFlashcardPanelCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="🃏" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Anki Flashcards" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowMcqPanelCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="📝" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  MCQ Quiz" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowTagInferenceCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="🏷" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Tag Inference" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding ShowHeatmapCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="🔥" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="  Streak" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                        <Button Command="{Binding NavigateToDocumentationCommand}"
                                Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock Text="?" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBlock Text="  Documentation" FontSize="14" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="1" Height="1" Background="{StaticResource SurfaceBgBrush}" Margin="0,0,0,12"/>
                    <Button Grid.Row="2" Command="{Binding OpenSettingsCommand}"
                            Background="{StaticResource SurfaceBgBrush}" Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8"
                            HorizontalAlignment="Stretch">
                        <DockPanel>
                            <TextBlock Text="⚙" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="  Settings" FontSize="14" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Button>
                </Grid>
            </Border>
        </Border>
    </Panel>
</UserControl>