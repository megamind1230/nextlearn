<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NextLearn.Desktop.ViewModels"
             xmlns:models="using:NextLearn.Desktop.Models"
             x:Class="NextLearn.Desktop.Controls.CommandPalette"
             x:DataType="vm:MainWindowViewModel">
  <Panel IsVisible="{Binding IsCommandPaletteOpen}">
    <Border Background="#00000000" PointerPressed="CloseOnBackdrop"/>

    <Grid VerticalAlignment="Bottom">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}" CornerRadius="8,8,0,0"
              Margin="8,0,8,0" Padding="4,4,14,4" MaxHeight="240"
              BorderThickness="1,1,1,0" BorderBrush="{StaticResource BorderDefaultBrush}"
              IsVisible="{Binding HasFilteredCommands}">
        <ScrollViewer Name="CommandListScrollViewer">
          <ListBox Name="CommandListBox"
                   ItemsSource="{Binding FilteredCommandPaletteEntries}"
                   SelectedItem="{Binding SelectedCommand}"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:CommandPaletteEntry">
                <Border Padding="8,6" Margin="2,1" CornerRadius="4"
                        PointerPressed="OnItemPointerPressed">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                               FontFamily="Consolas,Monospace"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextAccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Description}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="{Binding ShortcutText}"
                               FontSize="12" Foreground="{StaticResource AccentSelectionBrush}"
                               Margin="8,0,8,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding AliasesText}"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,0"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource SurfaceBgBrush}"/>
                <Setter Property="CornerRadius" Value="4"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource CommandPaletteHoverBgBrush}"/>
                <Setter Property="CornerRadius" Value="4"/>
              </Style>
            </ListBox.Styles>
          </ListBox>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="1" Height="30" Background="{StaticResource PageBgBrush}" Padding="8,0"
              BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderDefaultBrush}">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0" Text=":" FontSize="16" FontWeight="Bold"
                     Foreground="{StaticResource TextAccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
          <TextBox Grid.Column="1" Name="CommandInput"
                   Text="{Binding CommandPaletteInput}"
                   Watermark="type a command..."
                   FontSize="14" FontFamily="Consolas,Monospace"
                   Padding="4,0" Background="Transparent"
                   Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                   KeyDown="OnTextBoxKeyDown"/>
        </Grid>
      </Border>
    </Grid>
  </Panel>
</UserControl>